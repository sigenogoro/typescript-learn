{
  "name": "typescript-learn",
  "version": "1.0.0",
  "description": "TypeScript学習プロジェクト（NestJS互換環境）",
  "scripts": {
    "setup": "npm install",
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest",
    "test:run": "vitest run",
    "basics:1": "tsx src/01-basics/01-basic-types.ts",
    "basics:2": "tsx src/01-basics/02-type-inference.ts",
    "basics:3": "tsx src/01-basics/03-union-intersection.ts"
  },
  "dependencies": {
    "inquirer": "^8.2.6",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.10",
    "@types/node": "^22.15.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
